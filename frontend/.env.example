# Auth0 — SPA application settings
# Find these values in your Auth0 dashboard → Applications → your SPA app
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_spa_client_id_here

# Auth0 — API audience
# Find this in Auth0 dashboard → APIs → your API → identifier
VITE_AUTH0_AUDIENCE=https://your-api-identifier

# Backend base URL (defaults to http://localhost:8080 if omitted)
# For production: set to your API Gateway or deployed backend URL
VITE_API_BASE_URL=http://localhost:8080
